<% layout("layouts/boilerplate") %>

<div class="row">
    <div class="col-md-8 offset-md-3">

        <h3> <%= listing.title %></h3>
    </div>
    <div class="card listing-card col-md-6 offset-md-3">
        <img src="<%= listing.image.length > 0? listing.image[0].url:"" %>" class="card-img-top show-img" alt="listing_image" >
        <div class="card-body">
                <p>Owned by <b><i><%= listing.owner.username %></i></b></p>
                <p><%= listing.description %></p>
                <p>&#8377;<%= listing.price.toLocaleString("en-IN") %> </p>
                <p><%= listing.location %> </p>
                <p><%= listing.country %></p>
        </div>
    </div>
</div>

<% if(currUser && currUser._id.equals(listing.owner._id)){ %>
    <div class="btns">
        <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark col-3 offset-3 add-btn">Edit</a>
        <form method="post" action="/listings/<%= listing.id %>?_method=DELETE">
            <button class="btn btn-dark offset-3 ">DELETE</button>
        </form>
    </div>
<% } %>





<% if(isLogged){ %>
    <div class="col-md-8 offset-md-2">
        <hr>
        <h4>Leave a Review</h4>
        <form method="POST" 
                action="/listings/<%= listing._id %>/reviews "
                novalidate 
                class="needs-validation" >
            
            <div class="mb-3">
                <fieldset class="starability-slot">
                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                    <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                    <label for="first-rate1" title="Terrible">1 star</label>
                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                    <label for="first-rate2" title="Not good">2 stars</label>
                    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                    <label for="first-rate3" title="Average">3 stars</label>
                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                    <label for="first-rate4" title="Very good">4 stars</label>
                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                    <label for="first-rate5" title="Amazing">5 stars</label>
                </fieldset>
             </div>
            <div class="mb-3">
                <label for="comment" 
                        class="form-label">Comments</label>
                <textarea name="review[comment]" 
                            id="comment" 
                            class="form-control" 
                            required></textarea>
                <div class="invalid-feedback">Please write a comment!</div>
            </div>
            <br>
            <button class="btn btn-dark add-btn">Submit</button>
        </form>
        <br>
    </div>
<% } %>


<div class="row col-md-8 offset-md-2">
    <hr>
    <p><b>All Reviews</b></p>
    <%if(!listing.review.length){%>
        <P>no review</P>
    <% } %>
    <% for(review of listing.review){ %>
        <div class="card ms-4 me-2 col-6 col-md-5 mb-4">
            <div class="card-body">
                <h5 class="card-title">@<%= review.author.username %></h5>
                <p class="starability-result" data-rating="<%= review.rating %>">
                    Rated: 3 stars
                </p>
                <p class="card-text"><%= review.comment %></p>
            </div>
            <% if(isLogged && currUser._id.equals(review.author._id)){%>
            <form method="POST" action="/listings/<%=listing._id %>/reviews/<%= review._id %>?_method=DELETE" class="mb-2">
                        <button class="btn btn-sm btn-dark">Delete</button>
            </form>
            <% } %>
        </div>
    <% } %>
</div>

<div class="row">
    <div class="col-md-8 offset-md-2">
        <hr>
        <br>
        <h4>Where you'll be</h4>
        <div id="map" style="height: 300px;"></div>
    </div>
</div>


<script>
    const lng = <%= listing.geometry.coordinates[0]%>;
    const lat = <%= listing.geometry.coordinates[1]%>;
</script>