<style>
  .btn-search,.btn-search:hover{
    background-color: #fe424d;
    color: #fff;
    border-radius: 25px;
    padding: 0 1rem 0 1rem;
  }

  .btn-search i{
    display: inline;
    margin-right: 0.5rem;
  }

  .input{
    border-radius: 25px;
    padding: 0.5rem 3rem 0.5rem 3rem;
  }

.btn-search{
  background-color: #fe424d;
  color: #fff;
  border-radius: 25px;
  padding: 0rem 1rem;
  white-space: nowrap;
}

.btn-search:hover{
  background-color: #fe424d;
  color: #fff;
}

.btn-search i{
  margin-right: 0.4rem;
}

.input{
  border-radius: 25px;
  padding: 0.4rem 1rem;
  width: 100%;
}

@media (max-width: 768px){
  .btn-search span{
    display: none;
  }

  .btn-search{
    padding: 0.4rem 0.7rem;
  }
}
</style>

<nav class="navbar navbar-expand-lg bg-body-light border-bottom">
  <div class="container-fluid">

    <a class="navbar-brand" href="/listings">
      <i class="fa-solid fa-compass"></i> 
    </a>

    <button class="navbar-toggler" type="button"
            data-bs-toggle="collapse"
            data-bs-target="#navbarNavAltMarkup">
            <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav">
        <a class="nav-link" href="/listings">Explore</a>
      </div>
      <div class="navbar-nav ms-auto me-auto">
          <form action="/listings" method="get" class="d-flex " role="search" >
            <input class="form-control me-2 input" type="search" placeholder="Search destinations" aria-label="Search" name="search"/>
            <button class="btn btn-search" type="submit"><i class="fa-solid fa-magnifying-glass"></i><span>Search</span></button>
          </form>
      </div>
    </div>

    <div class="navbar-nav ms-auto">
      <a class="nav-link" href="/listings/new">Airbnb your home</a>
      <% if(!isLogged){%>
        <a class="nav-link" href="/signup"><b>Sign up</b></a>
        <a class="nav-link" href="/login"><b>Log in</b></a>
      <% } %>
      <% if(isLogged){ %>
        <a class="nav-link" href="/logout"><b>Log out</b></a>
      <% } %>
    </div>

  </div>
</nav>